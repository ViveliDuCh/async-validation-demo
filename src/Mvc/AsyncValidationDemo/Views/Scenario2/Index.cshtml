@model Order
@{ ViewData["Title"] = "Scenario 2"; }

<h3>Scenario 2: Order</h3>
<p>
    <code>Order</code> mixes async attributes with <code>IValidatableObject</code>
    cross-property validation.
</p>
<div class="alert alert-warning">
    <strong>Note:</strong> Client-side validation runs synchronous rules first. If a client-side rule
    fails, the form is not posted, so async validation will not run until those errors are fixed.
</div>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="ProductName" class="form-label"></label>
        <input asp-for="ProductName" class="form-control" />
        <span asp-validation-for="ProductName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantity" class="form-label"></label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UnitPrice" class="form-label"></label>
        <input asp-for="UnitPrice" class="form-control" />
        <span asp-validation-for="UnitPrice" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Delay" class="form-label"></label>
        <input asp-for="Delay" class="form-control" />
        <span asp-validation-for="Delay" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Validate</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
