@{ ViewData["Title"] = "Home"; }

<h2>MVC Async Validation Demo</h2>
<p>
    This sample combines the four API proposal scenarios with a DI-backed infrastructure error demo.
    MVC's async validation pipeline populates <code>ModelState</code> during model binding through
    <code>IAsyncModelValidator.ValidateAsync</code>.
</p>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Scenario 1: User</h5>
                <p class="card-text">
                    Mixed sync and async property validation with <code>[IsValidName]</code> and
                    <code>[UsernameAvailableAsync]</code>.
                </p>
                <a asp-controller="Scenario1" class="btn btn-primary">Open Scenario →</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Scenario 2: Order</h5>
                <p class="card-text">
                    Async attributes plus <code>IValidatableObject</code> cross-property business rules.
                </p>
                <a asp-controller="Scenario2" class="btn btn-primary">Open Scenario →</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Scenario 3: MoneyTransfer</h5>
                <p class="card-text">
                    Async cross-property validation through <code>IAsyncValidatableObject</code>.
                </p>
                <a asp-controller="Scenario3" class="btn btn-primary">Open Scenario →</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Scenario 4: Event</h5>
                <p class="card-text">
                    Async entity-level validation with <code>[AsyncDateRangeValid]</code> and
                    <code>IValidatableObject</code>.
                </p>
                <a asp-controller="Scenario4" class="btn btn-primary">Open Scenario →</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100 border-danger">
            <div class="card-body">
                <h5 class="card-title">Error Handling</h5>
                <p class="card-text">
                    DI-backed <code>UserRegistration</code> validation throws when username is
                    <code>error-trigger</code>, demonstrating error propagation through the middleware pipeline.
                </p>
                <a asp-controller="ErrorHandling" class="btn btn-danger">Open Form →</a>
            </div>
        </div>
    </div>
</div>
