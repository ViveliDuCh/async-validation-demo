<!DOCTYPE html>
<html>
<head>
    <title>MVC Async Validation Demo - @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        .field-validation-error { color: #dc3545; font-size: 0.875rem; }
        .validation-summary-errors { color: #dc3545; }
        .input-validation-error { border-color: #dc3545; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home">MVC Async Validation Demo</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Scenario1">Scenario 1</a>
                <a class="nav-link" asp-controller="Scenario2">Scenario 2</a>
                <a class="nav-link" asp-controller="Scenario3">Scenario 3</a>
                <a class="nav-link" asp-controller="Scenario4">Scenario 4</a>
                <a class="nav-link" asp-controller="ErrorHandling">Error Demo</a>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
