@model MoneyTransfer
@{ ViewData["Title"] = "Scenario 3"; }

<h3>Scenario 3: MoneyTransfer</h3>
<p>
    <code>MoneyTransfer</code> demonstrates async cross-property validation through
    <code>IAsyncValidatableObject</code>.
</p>
<div class="alert alert-warning">
    <strong>Note:</strong> Client-side validation runs synchronous rules first. If a client-side rule
    fails, the form is not posted, so async validation will not run until those errors are fixed.
</div>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="FromAccount" class="form-label"></label>
        <input asp-for="FromAccount" class="form-control" />
        <span asp-validation-for="FromAccount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ToAccount" class="form-label"></label>
        <input asp-for="ToAccount" class="form-control" />
        <span asp-validation-for="ToAccount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Validate</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
