@model UserRegistration
@{ ViewData["Title"] = "User Registration"; }

<h3>DI Service Resolution + Async Uniqueness Validation</h3>
<p>
    <code>[UniqueUsername]</code> and <code>[UniqueEmail]</code> resolve <code>UserService</code>
    from DI during model binding via MVC's <code>IAsyncModelValidator.ValidateAsync</code> pipeline.
</p>
<div class="alert alert-warning">
    <strong>Note:</strong> Client-side jQuery validation runs <strong>before</strong> the form submits.
    If a sync attribute (e.g., <code>[StringLength]</code> on Password) fails client-side, the form
    is blocked from posting — so server-side async validators like <code>[UniqueUsername]</code> and
    <code>[UniqueEmail]</code> won't run until all client-side errors are fixed. This is standard MVC
    behavior: client-side validates sync rules instantly, while async rules require a server round-trip.
</div>
<p class="text-muted">
    Try <code>admin</code> / <code>admin@example.com</code> / <code>adminPass</code> or
    <code>x@blocked.com</code>.
</p>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" type="password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
