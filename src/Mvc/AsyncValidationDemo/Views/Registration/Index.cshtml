@model UserRegistration
@{ ViewData["Title"] = "User Registration"; }

<h3>DI Service Resolution + Async Uniqueness Validation</h3>
<p>
    <code>[UniqueUsername]</code> and <code>[UniqueEmail]</code> resolve <code>UserService</code>
    from DI via <code>ValidationContext.GetService&lt;UserService&gt;()</code> during
    <code>Validator.TryValidateObjectAsync</code> — the controller passes
    <code>HttpContext.RequestServices</code> into the validation context.
</p>
<p class="text-muted">
    Try "admin" / "admin@example.com" (taken) or "newuser" / "new@example.com" (available).
</p>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" type="password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
