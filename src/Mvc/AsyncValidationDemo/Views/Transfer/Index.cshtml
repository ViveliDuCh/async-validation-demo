@model MoneyTransfer
@{ ViewData["Title"] = "Money Transfer"; }

<h3>IAsyncValidatableObject — Money Transfer</h3>
<p>
    <code>MoneyTransfer</code> implements <code>IAsyncValidatableObject</code>. The controller
    awaits <code>Validator.TryValidateObjectAsync()</code> after attribute validation passes.
    Default values trigger both errors: same account + insufficient funds ($500 balance).
</p>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="FromAccount" class="form-label"></label>
        <input asp-for="FromAccount" class="form-control" />
        <span asp-validation-for="FromAccount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ToAccount" class="form-label"></label>
        <input asp-for="ToAccount" class="form-control" />
        <span asp-validation-for="ToAccount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Transfer</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
