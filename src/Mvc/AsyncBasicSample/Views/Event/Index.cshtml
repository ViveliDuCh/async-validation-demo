@model Event
@{ ViewData["Title"] = "Event Validation"; }

<h3>Scenario 3: Entity-Level Attribute (Cross-Field)</h3>
<p>
    <code>[AsyncDateRangeValid]</code> is a class-level async attribute that validates
    StartDate &lt; EndDate. Because it targets the <strong>class</strong> (not a property),
    the async validation error appears in the <strong>validation summary</strong>.
</p>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Delay" class="form-label">I/O Delay (ms)</label>
        <input asp-for="Delay" class="form-control" />
        <span asp-validation-for="Delay" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Validate</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
