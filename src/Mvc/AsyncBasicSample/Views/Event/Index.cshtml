@model Event
@{ ViewData["Title"] = "Event Validation"; }

<h3>Scenario 2: Event Validation with IValidatableObject</h3>
<p>
    <code>Event</code> uses <code>[ReservedTitleCheck]</code>, <code>[DateRange]</code>,
    <code>[AsyncScheduleCheck]</code>, and <code>IValidatableObject</code>. Try
    <code>Test Event</code> with a New Year's Day start date and an end date before the start date.
</p>
<div class="alert alert-warning">
    <strong>Note:</strong> Client-side validation (jQuery) runs sync attributes first. If a sync rule
    fails client-side, the form won't submit — so async attributes like <code>[ReservedTitleCheck]</code>
    and <code>[AsyncScheduleCheck]</code> won't run until all client-side errors are fixed.
</div>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Delay" class="form-label">I/O Delay (ms)</label>
        <input asp-for="Delay" class="form-control" />
        <span asp-validation-for="Delay" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Validate</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
