@model User
@{ ViewData["Title"] = "User Validation"; }

<h3>Scenarios 1 &amp; 2: Reusable Property Attributes</h3>
<p>
    <code>[IsValidName]</code> simulates a profanity-check service with <code>Task.Delay</code>
    (async, non-blocking). <code>[AsyncOnlyEmailDomain("contoso.com")]</code> simulates a DNS
    lookup with <code>Task.Delay</code> (async, non-blocking). Try changing the email to a
    non-contoso.com address to see the error.
</p>

@if (ViewBag.SuccessMessage is not null)
{
    <div class="alert alert-success">@ViewBag.SuccessMessage</div>
}

<form asp-action="Index" method="post" class="col-md-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Delay" class="form-label">I/O Delay (ms)</label>
        <input asp-for="Delay" class="form-control" />
        <span asp-validation-for="Delay" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Validate</button>
    <a asp-controller="Home" class="btn btn-outline-secondary ms-2">← Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
