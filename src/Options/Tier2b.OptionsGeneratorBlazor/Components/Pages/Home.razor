@page "/"
@using Microsoft.Extensions.Options
@using Options.Shared
@inject IOptions<CloudInfoOptions> CloudInfoOptions

<h3>Tier 2b — Options Source Generator Async Validation Demo</h3>
<p>
    Same result as Tier 2, but validation was performed by the
    <strong>source-generated</strong> <code>CloudInfoOptionsValidator</code>
    instead of the reflection-based
    <code>DataAnnotationValidateOptionsAsync&lt;T&gt;</code>.
</p>
<p>
    The generated validator calls <code>Validator.TryValidateValueAsync()</code>
    per property at compile time — no reflection, AOT-friendly.
</p>

@if (cloudInfo is not null)
{
    <div class="card mt-3">
        <div class="card-header">CloudInfoOptions (validated at startup via source generator)</div>
        <div class="card-body">
            <ul class="list-unstyled mb-0">
                <li><strong>Storage:</strong> @cloudInfo.Storage</li>
                <li><strong>Region:</strong> @cloudInfo.Region</li>
                <li><strong>Endpoint:</strong> @cloudInfo.Endpoint</li>
            </ul>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">CloudInfoOptions is null — this should not happen.</div>
}

@code {
    private CloudInfoOptions? cloudInfo;

    protected override void OnInitialized()
    {
        cloudInfo = CloudInfoOptions.Value;
    }
}
