{
  "Scenarios": {
    "BothValid": {
      "Database": {
        "ConnectionString": "Server=db.contoso.com;Database=AppDb;Trusted_Connection=true",
        "CommandTimeoutSeconds": 60
      },
      "Cache": {
        "Endpoint": "redis.contoso.com:6379",
        "DefaultTtlSeconds": 600
      }
    },
    "CacheFails": {
      "Database": {
        "ConnectionString": "Server=db.contoso.com;Database=AppDb;Trusted_Connection=true",
        "CommandTimeoutSeconds": 60
      },
      "Cache": {
        "Endpoint": "invalid-cache.example.com:6379",
        "DefaultTtlSeconds": 600
      }
    },
    "BothFail": {
      "Database": {
        "ConnectionString": "Server=invalid-db.example.com;Database=AppDb",
        "CommandTimeoutSeconds": 60
      },
      "Cache": {
        "Endpoint": "invalid-cache.example.com:6379",
        "DefaultTtlSeconds": 600
      }
    }
  }
}
