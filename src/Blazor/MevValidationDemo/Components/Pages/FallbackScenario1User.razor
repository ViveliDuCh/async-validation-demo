@page "/fallback-scenario-1-user"

<h3>Scenario 1 — Fallback User</h3>
<p>
    <code>SharedModels.User</code> does <strong>not</strong> have <code>[ValidatableType]</code>,
    so <code>DataAnnotationsValidator</code> falls back to
    <code>ValidateWithDefaultValidatorAsync</code> → <code>Validator.TryValidateObjectAsync()</code>.
    The same sync and async attributes run, but through the runtime validator pipeline.
</p>
<div class="alert alert-secondary">
    <strong>Code path:</strong> <code>ValidateWithDefaultValidatorAsync</code> → <code>Validator.TryValidateObjectAsync()</code> → two-phase execution
</div>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="fallbackScenario1UserForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="_user.Name" />
        <ValidationMessage For="@(() => _user.Name)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_user.Username" />
            @if (_editContext.IsValidationPending(() => _user.Username))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _user.Username)" />
    </div>

    <button type="submit" class="btn btn-secondary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating (Fallback)...
        }
        else
        {
            @:Submit (Fallback Path)
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly User _user = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_user);
        _editContext.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Fallback path: User valid via Validator.TryValidateObjectAsync()."
                : "❌ Fallback path: validation failed — see user errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
