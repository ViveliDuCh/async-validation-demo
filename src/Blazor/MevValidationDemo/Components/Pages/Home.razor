    </a>
    <a href="/fallback-scenario-1-user" class="list-group-item list-group-item-action list-group-item-secondary">
        <strong>Fallback User:</strong> <code>SharedModels.User</code> without <code>[ValidatableType]</code>
    </a>
    <a href="/comparison" class="list-group-item list-group-item-action list-group-item-success">
