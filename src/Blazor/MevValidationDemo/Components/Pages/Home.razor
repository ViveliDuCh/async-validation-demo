<h4>Code Path Decision</h4>
<table class="table table-bordered table-sm">
    <thead class="table-light">
        <tr>
            <th>Condition</th>
            <th>Code Path</th>
            <th>Method Chain</th>
        </tr>
    </thead>
    <tbody>
        <tr class="table-primary">
            <td><code>AddValidation()</code> + <code>[ValidatableType]</code></td>
            <td><strong>MEV</strong></td>
            <td><code>TryValidateTypeInfoAsync</code> → generated validators → async members/interfaces</td>
        </tr>
        <tr class="table-secondary">
            <td><code>AddValidation()</code> + no <code>[ValidatableType]</code></td>
            <td><strong>Fallback</strong></td>
            <td><code>ValidateWithDefaultValidatorAsync</code> → <code>Validator.TryValidateObjectAsync()</code></td>
        </tr>
    </tbody>
</table>
