@page "/fallback-order"

<h3>Fallback Path — Order (IAsyncValidatableObject)</h3>
<p>
    <code>SharedModels.Order</code> does <strong>not</strong> have <code>[ValidatableType]</code>,
    so <code>DataAnnotationsValidator</code> falls back to <code>ValidateWithDefaultValidatorAsync</code>
    → <code>Validator.TryValidateObjectAsync()</code>. The same <code>IAsyncValidatableObject</code>
    and async property attributes run, but through the runtime Validator.
</p>
<div class="alert alert-secondary">
    <strong>Code path:</strong> <code>ValidateWithDefaultValidatorAsync</code> → <code>Validator.TryValidateObjectAsync()</code> → <code>IAsyncValidatableObject.ValidateAsync()</code>
</div>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="fallbackOrderForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Product Name</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_order.ProductName" />
            @if (_editContext.IsValidationPending(() => _order.ProductName))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _order.ProductName)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <InputNumber class="form-control" @bind-Value="_order.Quantity" />
        <ValidationMessage For="@(() => _order.Quantity)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Unit Price</label>
        <InputNumber class="form-control" @bind-Value="_order.UnitPrice" />
        <ValidationMessage For="@(() => _order.UnitPrice)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_order.Delay" />
        <ValidationMessage For="@(() => _order.Delay)" />
    </div>

    <button type="submit" class="btn btn-secondary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating (Fallback)...
        }
        else
        {
            @:Submit (Fallback Path)
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Order _order = new()
    {
        ProductName = "Gadget",
        Quantity = 6_000,
        UnitPrice = 10m,
        Delay = 100
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_order);
        _editContext.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Fallback path: Order valid via Validator.TryValidateObjectAsync!"
                : "❌ Fallback path: validation failed — see order errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
