@page "/comparison"

<h3>Scenario 1 Comparison — MEV vs Fallback User</h3>
<p>
    Both panels use <code>&lt;DataAnnotationsValidator /&gt;</code> with the same
    <code>Name</code> + <code>Username</code> rules. The only difference is whether the model has
    <code>[ValidatableType]</code>, which determines whether Blazor uses the MEV source-gen path
    or the runtime fallback validator.
</p>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <strong>MEV Path</strong>
                <span class="badge bg-light text-dark ms-2">[ValidatableType]</span>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    <code>MevUser</code> → <code>TryValidateTypeInfoAsync</code> → <code>GetValidationResultAsync()</code>
                </p>
                <EditForm EditContext="@_editContextMev" OnSubmit="@HandleSubmitMev" FormName="cmpMevUserForm">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_userMev.Name" />
                        <ValidationMessage For="@(() => _userMev.Name)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <div class="input-group">
                            <InputText class="form-control" @bind-Value="_userMev.Username" />
                            @if (_editContextMev.IsValidationPending(() => _userMev.Username))
                            {
                                <span class="input-group-text">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                </span>
                            }
                        </div>
                        <ValidationMessage For="@(() => _userMev.Username)" />
                    </div>
                    <button type="submit" class="btn btn-primary" disabled="@(_isSubmittingMev || _editContextMev.IsValidationPending())">
                        @(_isSubmittingMev || _editContextMev.IsValidationPending() ? "Validating (MEV)..." : "Submit (MEV)")
                    </button>
                    <ValidationSummary class="mt-3" />
                </EditForm>
                @if (_messageMev is not null)
                {
                    <div class="alert @_alertClassMev mt-3">@_messageMev</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <strong>Fallback Path</strong>
                <span class="badge bg-warning text-dark ms-2">No [ValidatableType]</span>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    <code>SharedModels.User</code> → <code>ValidateWithDefaultValidatorAsync</code> → <code>TryValidateObjectAsync()</code>
                </p>
                <EditForm EditContext="@_editContextFb" OnSubmit="@HandleSubmitFb" FormName="cmpFallbackUserForm">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_userFb.Name" />
                        <ValidationMessage For="@(() => _userFb.Name)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <div class="input-group">
                            <InputText class="form-control" @bind-Value="_userFb.Username" />
                            @if (_editContextFb.IsValidationPending(() => _userFb.Username))
                            {
                                <span class="input-group-text">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                </span>
                            }
                        </div>
                        <ValidationMessage For="@(() => _userFb.Username)" />
                    </div>
                    <button type="submit" class="btn btn-secondary" disabled="@(_isSubmittingFb || _editContextFb.IsValidationPending())">
                        @(_isSubmittingFb || _editContextFb.IsValidationPending() ? "Validating (Fallback)..." : "Submit (Fallback)")
                    </button>
                    <ValidationSummary class="mt-3" />
                </EditForm>
                @if (_messageFb is not null)
                {
                    <div class="alert @_alertClassFb mt-3">@_messageFb</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly MevUser _userMev = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private EditContext _editContextMev = null!;
    private bool _isSubmittingMev;
    private string? _messageMev;
    private string _alertClassMev = "alert-info";

    private readonly User _userFb = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private EditContext _editContextFb = null!;
    private bool _isSubmittingFb;
    private string? _messageFb;
    private string _alertClassFb = "alert-info";

    protected override void OnInitialized()
    {
        _editContextMev = new EditContext(_userMev);
        _editContextMev.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);

        _editContextFb = new EditContext(_userFb);
        _editContextFb.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmitMev()
    {
        _isSubmittingMev = true;
        _messageMev = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            bool isValid = await _editContextMev.ValidateAsync();
            _messageMev = isValid
                ? "✅ MEV: user valid via GetValidationResultAsync"
                : "❌ MEV: user failed via GetValidationResultAsync";
            _alertClassMev = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmittingMev = false;
        }
    }

    private async Task HandleSubmitFb()
    {
        _isSubmittingFb = true;
        _messageFb = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            bool isValid = await _editContextFb.ValidateAsync();
            _messageFb = isValid
                ? "✅ Fallback: user valid via TryValidateObjectAsync"
                : "❌ Fallback: user failed via TryValidateObjectAsync";
            _alertClassFb = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmittingFb = false;
        }
    }
}
