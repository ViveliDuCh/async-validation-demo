@page "/fallback-scenario-3-transfer"

<h3>Scenario 3 — Fallback Money Transfer (IAsyncValidatableObject)</h3>
<p>
    <code>SharedModels.MoneyTransfer</code> does <strong>not</strong> have <code>[ValidatableType]</code>,
    so <code>DataAnnotationsValidator</code> routes validation through
    <code>ValidateWithDefaultValidatorAsync</code> → <code>Validator.TryValidateObjectAsync()</code> →
    <code>IAsyncValidatableObject.ValidateAsync()</code>.
</p>
<div class="alert alert-secondary">
    <strong>Code path:</strong> <code>ValidateWithDefaultValidatorAsync</code> → <code>Validator.TryValidateObjectAsync()</code> → <code>IAsyncValidatableObject.ValidateAsync()</code>
</div>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="fallbackScenario3TransferForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">From Account</label>
        <InputText class="form-control" @bind-Value="_transfer.FromAccount" />
        <ValidationMessage For="@(() => _transfer.FromAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">To Account</label>
        <InputText class="form-control" @bind-Value="_transfer.ToAccount" />
        <ValidationMessage For="@(() => _transfer.ToAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <InputNumber class="form-control" @bind-Value="_transfer.Amount" />
        <ValidationMessage For="@(() => _transfer.Amount)" />
    </div>

    <button type="submit" class="btn btn-secondary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating (Fallback)...
        }
        else
        {
            @:Submit (Fallback Path)
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly MoneyTransfer _transfer = new()
    {
        FromAccount = "CHK-100",
        ToAccount = "CHK-100",
        Amount = 600m
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_transfer);
        _editContext.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Fallback path: transfer valid via Validator.TryValidateObjectAsync()."
                : "❌ Fallback path: validation failed — see transfer errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
