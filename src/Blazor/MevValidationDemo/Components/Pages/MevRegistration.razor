@page "/mev-registration"
@inject IServiceProvider ServiceProvider

<h3>MEV Path — Registration</h3>
<p>
    <code>MevUserRegistration</code> has <code>[ValidatableType]</code>, so
    <code>DataAnnotationsValidator</code> uses the <strong>MEV source-gen path</strong>:
    <code>TryValidateTypeInfoAsync</code> → <code>GetValidationResultAsync()</code> for each
    async attribute. DI-backed <code>[UniqueUsername]</code> and <code>[UniqueEmail]</code>
    resolve <code>UserService</code> through this path.
</p>
<div class="alert alert-info">
    <strong>Code path:</strong> <code>TryValidateTypeInfoAsync</code> → <code>IValidatableInfo.ValidateAsync</code> → <code>asyncAttr.GetValidationResultAsync()</code>
</div>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="mevRegForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_registration.Username" />
            @if (_editContext.IsValidationPending(() => _registration.Username))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _registration.Username)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <div class="input-group">
            <InputText class="form-control" type="email" @bind-Value="_registration.Email" />
            @if (_editContext.IsValidationPending(() => _registration.Email))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _registration.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_registration.Password" />
        <ValidationMessage For="@(() => _registration.Password)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating (MEV)...
        }
        else
        {
            @:Submit (MEV Path)
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Models.MevUserRegistration _registration = new()
    {
        Username = "admin",
        Email = "admin@example.com",
        Password = "SecureP@ss123"
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_registration);
        _editContext.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ MEV path: all validation passed via source-gen GetValidationResultAsync!"
                : "❌ MEV path: validation failed — see errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
