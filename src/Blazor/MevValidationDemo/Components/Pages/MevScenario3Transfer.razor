@page "/mev-scenario-3-transfer"

<h3>Scenario 3 — MEV Money Transfer (IAsyncValidatableObject)</h3>
<p>
    <code>MevMoneyTransfer</code> has <code>[ValidatableType]</code> and implements
    <code>IAsyncValidatableObject</code>. The MEV source-gen path reaches the async
    <code>ValidateAsync()</code> cross-property rule without falling back to the runtime validator.
</p>
<div class="alert alert-info">
    <strong>Code path:</strong> <code>TryValidateTypeInfoAsync</code> → <code>IAsyncValidatableObject.ValidateAsync()</code>
</div>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="mevScenario3TransferForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">From Account</label>
        <InputText class="form-control" @bind-Value="_transfer.FromAccount" />
        <ValidationMessage For="@(() => _transfer.FromAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">To Account</label>
        <InputText class="form-control" @bind-Value="_transfer.ToAccount" />
        <ValidationMessage For="@(() => _transfer.ToAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <InputNumber class="form-control" @bind-Value="_transfer.Amount" />
        <ValidationMessage For="@(() => _transfer.Amount)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating (MEV)...
        }
        else
        {
            @:Submit (MEV Path)
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly MevMoneyTransfer _transfer = new()
    {
        FromAccount = "CHK-100",
        ToAccount = "CHK-100",
        Amount = 600m
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_transfer);
        _editContext.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ MEV path: transfer valid via source-gen + IAsyncValidatableObject."
                : "❌ MEV path: validation failed — see transfer errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
