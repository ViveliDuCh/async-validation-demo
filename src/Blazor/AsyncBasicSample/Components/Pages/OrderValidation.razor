@page "/order"

<h3>Scenario 4: IAsyncValidatableObject — Cross-Property (Order)</h3>
<p>
    <strong>Order</strong> implements <code>IAsyncValidatableObject.ValidateAsync</code>.
    Cross-property validation checks that total cost (Quantity × UnitPrice) does not exceed $50,000 while awaiting async I/O without blocking.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="orderForm">
    <div class="mb-3">
        <label class="form-label">Product Name</label>
        <InputText class="form-control" @bind-Value="_order.ProductName" />
        <ValidationMessage For="@(() => _order.ProductName)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <InputNumber class="form-control" @bind-Value="_order.Quantity" />
        <ValidationMessage For="@(() => _order.Quantity)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Unit Price</label>
        <InputNumber class="form-control" @bind-Value="_order.UnitPrice" />
        <ValidationMessage For="@(() => _order.UnitPrice)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_order.Delay" />
        <ValidationMessage For="@(() => _order.Delay)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
        @(_isSubmitting ? "Validating asynchronously..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Order _order = new()
    {
        ProductName = "Widget",
        Quantity = 10_000,
        UnitPrice = 10m,
        Delay = 3000
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_order);
        _messageStore = new ValidationMessageStore(_editContext);
    }

    private async Task HandleSubmit(EditContext _)
    {
        _isSubmitting = true;
        _messageStore.Clear();
        _message = null;
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_order);
        bool isValid = await Validator.TryValidateObjectAsync(_order, context, results, true);

        AddResultsToMessageStore(_order, results);
        _message = isValid
            ? "✅ Valid!"
            : "❌ Validation failed — see errors above while async cross-property checks completed without blocking.";
        _alertClass = isValid ? "alert-success" : "alert-danger";
        _isSubmitting = false;
    }

    private void AddResultsToMessageStore(object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                _messageStore.Add(_editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                _messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        _editContext.NotifyValidationStateChanged();
    }
}
