@page "/event"
@implements IDisposable

<h3>Scenario 3: Reusable Entity-Level Attribute (Cross-Field)</h3>
<p>
    <strong>AsyncDateRangeValid</strong> awaits a simulated async check before verifying that
    StartDate is before EndDate. Manual submit keeps Blazor's validation UI updated while async I/O runs without blocking.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="eventForm">
    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText class="form-control" @bind-Value="_event.Title" />
        <ValidationMessage For="@(() => _event.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <InputDate class="form-control" @bind-Value="_event.StartDate" />
        <ValidationMessage For="@(() => _event.StartDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <InputDate class="form-control" @bind-Value="_event.EndDate" />
        <ValidationMessage For="@(() => _event.EndDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_event.Delay" />
        <ValidationMessage For="@(() => _event.Delay)" />
    </div>

    <button type="submit" class="btn btn-primary">
        @(_isSubmitting ? "Validating asynchronously..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Event _event = new()
    {
        Title = "Launch Party",
        StartDate = new DateTime(2026, 12, 25),
        EndDate = new DateTime(2026, 12, 20),
        Delay = 3000
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private CancellationTokenSource? _cts;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_event);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += OnFieldChanged;
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (_cts is not null && !_cts.IsCancellationRequested)
        {
            _cts.Cancel();
        }
    }

    private async Task HandleSubmit(EditContext _)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        _isSubmitting = true;
        _messageStore.Clear();
        _message = null;
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_event);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_event, context, results, true, _cts.Token);

            AddResultsToMessageStore(_event, results);
            _message = isValid
                ? "✅ Valid! Async validation completed without blocking the server thread."
                : "❌ Validation failed — see errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore.Clear();
            _editContext.NotifyValidationStateChanged();
            _message = "⚠️ Validation cancelled — a field value changed.";
            _alertClass = "alert-warning";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void AddResultsToMessageStore(object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                _messageStore.Add(_editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                _messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        _editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext.OnFieldChanged -= OnFieldChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
