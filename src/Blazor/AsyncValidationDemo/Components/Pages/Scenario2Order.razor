@page "/scenario2"
@implements IDisposable

<h3>Scenario 2: Order — IValidatableObject + Async Attributes</h3>
<p>
    <code>Order</code> uses synchronous <code>IValidatableObject.Validate</code> rules together with
    async attributes like <code>[AsyncProductExists]</code> and <code>[AsyncInventoryCheck]</code>.
    The <code>Delay</code> field simulates external I/O while Blazor awaits validation.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="scenario2Form">
    <div class="mb-3">
        <label class="form-label">Product Name</label>
        <InputText class="form-control" @bind-Value="_order.ProductName" />
        <ValidationMessage For="@(() => _order.ProductName)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <InputNumber class="form-control" @bind-Value="_order.Quantity" />
        <ValidationMessage For="@(() => _order.Quantity)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Unit Price</label>
        <InputNumber class="form-control" @bind-Value="_order.UnitPrice" />
        <ValidationMessage For="@(() => _order.UnitPrice)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_order.Delay" />
        <ValidationMessage For="@(() => _order.Delay)" />
    </div>

    <button type="submit" class="btn btn-primary">
        @(_isSubmitting ? "Validating asynchronously..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Order _order = new()
    {
        ProductName = "Gadget",
        Quantity = 250,
        UnitPrice = 250m,
        Delay = 100
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private CancellationTokenSource? _cts;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_order);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += OnFieldChanged;
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (_cts is not null && !_cts.IsCancellationRequested)
        {
            _cts.Cancel();
        }
    }

    private async Task HandleSubmit(EditContext _)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        _isSubmitting = true;
        _messageStore.Clear();
        _message = null;
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_order);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_order, context, results, true, _cts.Token);

            AddResultsToMessageStore(_editContext, _messageStore, _order, results);
            _message = isValid
                ? "✅ Order valid!"
                : "❌ Validation failed — see order errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore.Clear();
            _editContext.NotifyValidationStateChanged();
            _message = "⚠️ Validation cancelled — a field value changed.";
            _alertClass = "alert-warning";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static void AddResultsToMessageStore(EditContext editContext, ValidationMessageStore messageStore, object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                messageStore.Add(editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext.OnFieldChanged -= OnFieldChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
