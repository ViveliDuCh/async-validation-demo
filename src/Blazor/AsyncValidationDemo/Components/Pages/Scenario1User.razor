@page "/scenario1"
@implements IDisposable

<h3>Scenario 1: User — Basic Async Property Validation</h3>
<p>
    <code>User</code> combines a synchronous <code>[IsValidName]</code> check with the async
    <code>[UsernameAvailableAsync]</code> attribute. This sample manually runs
    <code>Validator.TryValidateObjectAsync</code> and pushes results into the current <code>EditContext</code>.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="scenario1Form">
    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="_user.Name" />
        <ValidationMessage For="@(() => _user.Name)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Username</label>
        <InputText class="form-control" @bind-Value="_user.Username" />
        <ValidationMessage For="@(() => _user.Username)" />
    </div>

    <button type="submit" class="btn btn-primary">
        @(_isSubmitting ? "Validating asynchronously..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly User _user = new()
    {
        Name = "Bob",
        Username = "admin"
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private CancellationTokenSource? _cts;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_user);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += OnFieldChanged;
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (_cts is not null && !_cts.IsCancellationRequested)
        {
            _cts.Cancel();
        }
    }

    private async Task HandleSubmit(EditContext _)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        _isSubmitting = true;
        _messageStore.Clear();
        _message = null;
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_user);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_user, context, results, true, _cts.Token);

            AddResultsToMessageStore(_editContext, _messageStore, _user, results);
            _message = isValid
                ? "✅ User valid!"
                : "❌ Validation failed — see user errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore.Clear();
            _editContext.NotifyValidationStateChanged();
            _message = "⚠️ Validation cancelled — a field value changed.";
            _alertClass = "alert-warning";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static void AddResultsToMessageStore(EditContext editContext, ValidationMessageStore messageStore, object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                messageStore.Add(editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext.OnFieldChanged -= OnFieldChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
