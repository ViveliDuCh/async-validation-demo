@page "/cancellation"
@implements IDisposable

<h3>Cancellation Demo: MoneyTransfer</h3>
<p>
    This page validates a <strong>MoneyTransfer</strong> model and passes a
    <code>CancellationToken</code> into <code>Validator.TryValidateObjectAsync</code>.
    Start validation, then click <strong>Cancel</strong> to stop the in-flight async transfer checks.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="cancellationForm">
    <div class="mb-3">
        <label class="form-label">From Account</label>
        <InputText class="form-control" @bind-Value="_transfer.FromAccount" />
        <ValidationMessage For="@(() => _transfer.FromAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">To Account</label>
        <InputText class="form-control" @bind-Value="_transfer.ToAccount" />
        <ValidationMessage For="@(() => _transfer.ToAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <InputNumber class="form-control" @bind-Value="_transfer.Amount" />
        <ValidationMessage For="@(() => _transfer.Amount)" />
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            @(_isSubmitting ? "Validating asynchronously..." : "Submit")
        </button>
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelValidation" disabled="@(!_isSubmitting)">
            Cancel
        </button>
    </div>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly MoneyTransfer _transfer = new()
    {
        FromAccount = "checking",
        ToAccount = "checking",
        Amount = 1000m
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private CancellationTokenSource? _cts;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_transfer);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += OnFieldChanged;
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (_cts is not null && !_cts.IsCancellationRequested)
        {
            _cts.Cancel();
        }
    }

    private async Task HandleSubmit(EditContext _)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        _isSubmitting = true;
        _messageStore.Clear();
        _message = "Validation started. Click Cancel to stop the in-flight async transfer checks.";
        _alertClass = "alert-info";
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_transfer);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_transfer, context, results, true, _cts.Token);
            AddResultsToMessageStore(_transfer, results);
            _message = isValid
                ? "✅ Validation completed without cancellation."
                : "❌ Validation completed — see transfer errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore.Clear();
            _editContext.NotifyValidationStateChanged();
            _message = "⚠️ Validation was canceled before the async checks completed.";
            _alertClass = "alert-warning";
        }
        finally
        {
            _isSubmitting = false;
            _cts?.Dispose();
            _cts = null;
        }
    }

    private void CancelValidation()
    {
        _cts?.Cancel();
        _message = "Cancellation requested...";
        _alertClass = "alert-warning";
    }

    private void AddResultsToMessageStore(object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                _messageStore.Add(_editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                _messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        _editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext.OnFieldChanged -= OnFieldChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
