@page "/cancellation"
@implements IDisposable

<h3>Scenario 5: CancellationToken Propagation</h3>
<p>
    This page validates an <strong>Event</strong> model with delay-backed async checks and passes a
    <code>CancellationToken</code> into <code>Validator.TryValidateObjectAsync</code>.
    Start validation, then click <strong>Cancel</strong> to stop in-flight async validation without blocking the server thread.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="cancellationForm">
    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText class="form-control" @bind-Value="_event.Title" />
        <ValidationMessage For="@(() => _event.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <InputDate class="form-control" @bind-Value="_event.StartDate" />
        <ValidationMessage For="@(() => _event.StartDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <InputDate class="form-control" @bind-Value="_event.EndDate" />
        <ValidationMessage For="@(() => _event.EndDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_event.Delay" />
        <ValidationMessage For="@(() => _event.Delay)" />
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            @(_isSubmitting ? "Validating asynchronously..." : "Submit")
        </button>
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelValidation" disabled="@(!_isSubmitting)">
            Cancel
        </button>
    </div>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Event _event = new()
    {
        Title = "TBD Planning",
        StartDate = new DateTime(DateTime.Today.Year + 1, 1, 1),
        EndDate = new DateTime(DateTime.Today.Year + 1, 1, 2),
        Delay = 5000
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private CancellationTokenSource? _cts;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_event);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += OnFieldChanged;
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (_cts is not null && !_cts.IsCancellationRequested)
        {
            _cts.Cancel();
        }
    }

    private async Task HandleSubmit(EditContext _)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        _isSubmitting = true;
        _messageStore.Clear();
        _message = "Validation started. Click Cancel to stop the in-flight async checks.";
        _alertClass = "alert-info";
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_event);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_event, context, results, true, _cts.Token);
            AddResultsToMessageStore(_event, results);
            _message = isValid
                ? "✅ Validation completed without cancellation."
                : "❌ Validation completed — see event errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore.Clear();
            _editContext.NotifyValidationStateChanged();
            _message = "⚠️ Validation was canceled before the async checks completed.";
            _alertClass = "alert-warning";
        }
        finally
        {
            _isSubmitting = false;
            _cts?.Dispose();
            _cts = null;
        }
    }

    private void CancelValidation()
    {
        _cts?.Cancel();
        _message = "Cancellation requested...";
        _alertClass = "alert-warning";
    }

    private void AddResultsToMessageStore(object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                _messageStore.Add(_editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                _messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        _editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext.OnFieldChanged -= OnFieldChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
