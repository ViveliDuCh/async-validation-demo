@page "/registration"
@inject IServiceProvider ServiceProvider
@implements IDisposable

<h3>Scenarios 1 &amp; 2: DI Service Resolution + Two-Phase Validation</h3>
<p>
    <strong>Scenario 1:</strong> <code>UniqueUsername</code> and <code>UniqueEmail</code> resolve
    <code>UserService</code> from the DI container via <code>ValidationContext.GetService()</code>.
</p>
<p>
    <strong>Scenario 2:</strong> Async validation uses two phases. Synchronous attributes run first,
    so a failing <code>[EmailAddress]</code> prevents the async <code>[UniqueEmail]</code> check from running.
</p>

<h4>Scenario 1: Duplicate Detection</h4>
<EditForm EditContext="@_editContext1" OnSubmit="@HandleSubmit1" FormName="regForm1">
    <div class="mb-3">
        <label class="form-label">Username</label>
        <InputText class="form-control" @bind-Value="_registration1.Username" />
        <ValidationMessage For="@(() => _registration1.Username)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" @bind-Value="_registration1.Email" />
        <ValidationMessage For="@(() => _registration1.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_registration1.Password" />
        <ValidationMessage For="@(() => _registration1.Password)" />
    </div>

    <button type="submit" class="btn btn-primary">
        @(_isSubmitting1 ? "Validating asynchronously..." : "Submit")
    </button>
    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message1 is not null)
{
    <div class="alert @_alertClass1 mt-3">@_message1</div>
}

<hr class="my-4" />

<h4>Scenario 2: Invalid Email Format</h4>
<EditForm EditContext="@_editContext2" OnSubmit="@HandleSubmit2" FormName="regForm2">
    <div class="mb-3">
        <label class="form-label">Username</label>
        <InputText class="form-control" @bind-Value="_registration2.Username" />
        <ValidationMessage For="@(() => _registration2.Username)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" @bind-Value="_registration2.Email" />
        <ValidationMessage For="@(() => _registration2.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_registration2.Password" />
        <ValidationMessage For="@(() => _registration2.Password)" />
    </div>

    <button type="submit" class="btn btn-primary">
        @(_isSubmitting2 ? "Validating asynchronously..." : "Submit")
    </button>
    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message2 is not null)
{
    <div class="alert @_alertClass2 mt-3">@_message2</div>
}

@code {
    private readonly UserRegistration _registration1 = new()
    {
        Username = "admin",
        Email = "admin@example.com",
        Password = "SecureP@ss123"
    };

    private readonly UserRegistration _registration2 = new()
    {
        Username = "newuser",
        Email = "not-an-email",
        Password = "SecureP@ss123"
    };

    private EditContext _editContext1 = null!;
    private ValidationMessageStore _messageStore1 = null!;
    private CancellationTokenSource? _cts1;
    private EditContext _editContext2 = null!;
    private ValidationMessageStore _messageStore2 = null!;
    private CancellationTokenSource? _cts2;
    private bool _isSubmitting1;
    private bool _isSubmitting2;
    private string? _message1;
    private string _alertClass1 = "alert-info";
    private string? _message2;
    private string _alertClass2 = "alert-info";

    protected override void OnInitialized()
    {
        _editContext1 = new EditContext(_registration1);
        _messageStore1 = new ValidationMessageStore(_editContext1);
        _editContext1.OnFieldChanged += OnFieldChanged1;
        _editContext2 = new EditContext(_registration2);
        _messageStore2 = new ValidationMessageStore(_editContext2);
        _editContext2.OnFieldChanged += OnFieldChanged2;
    }

    private void OnFieldChanged1(object? sender, FieldChangedEventArgs e)
    {
        if (_cts1 is not null && !_cts1.IsCancellationRequested)
        {
            _cts1.Cancel();
        }
    }

    private void OnFieldChanged2(object? sender, FieldChangedEventArgs e)
    {
        if (_cts2 is not null && !_cts2.IsCancellationRequested)
        {
            _cts2.Cancel();
        }
    }

    private async Task HandleSubmit1(EditContext _)
    {
        _cts1?.Cancel();
        _cts1?.Dispose();
        _cts1 = new CancellationTokenSource();

        _isSubmitting1 = true;
        _messageStore1.Clear();
        _message1 = null;
        _editContext1.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_registration1, ServiceProvider, null);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_registration1, context, results, true, _cts1.Token);

            AddResultsToMessageStore(_editContext1, _messageStore1, _registration1, results);
            _message1 = isValid ? "✅ Valid!" : "❌ Validation failed — see duplicate detection errors above.";
            _alertClass1 = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore1.Clear();
            _editContext1.NotifyValidationStateChanged();
            _message1 = "⚠️ Validation cancelled — a field value changed.";
            _alertClass1 = "alert-warning";
        }
        finally
        {
            _isSubmitting1 = false;
        }
    }

    private async Task HandleSubmit2(EditContext _)
    {
        _cts2?.Cancel();
        _cts2?.Dispose();
        _cts2 = new CancellationTokenSource();

        _isSubmitting2 = true;
        _messageStore2.Clear();
        _message2 = null;
        _editContext2.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_registration2, ServiceProvider, null);

        // Two-phase behavior: sync [EmailAddress] runs before async [UniqueEmail].
        // Because "not-an-email" fails the sync phase, the async uniqueness check is skipped.
        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_registration2, context, results, true, _cts2.Token);

            AddResultsToMessageStore(_editContext2, _messageStore2, _registration2, results);
            _message2 = isValid
                ? "✅ Valid!"
                : "❌ Validation failed. The sync email-format check ran first, so the async UniqueEmail lookup was skipped.";
            _alertClass2 = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore2.Clear();
            _editContext2.NotifyValidationStateChanged();
            _message2 = "⚠️ Validation cancelled — a field value changed.";
            _alertClass2 = "alert-warning";
        }
        finally
        {
            _isSubmitting2 = false;
        }
    }

    private static void AddResultsToMessageStore(EditContext editContext, ValidationMessageStore messageStore, object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                messageStore.Add(editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext1.OnFieldChanged -= OnFieldChanged1;
        _cts1?.Cancel();
        _cts1?.Dispose();
        _editContext2.OnFieldChanged -= OnFieldChanged2;
        _cts2?.Cancel();
        _cts2?.Dispose();
    }
}
