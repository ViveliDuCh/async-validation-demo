@page "/scenario4"
@implements IDisposable

<h3>Scenario 4: Event — AsyncDateRangeValid</h3>
<p>
    <code>Event</code> uses the async entity-level <code>[AsyncDateRangeValid]</code> attribute to simulate
    a calendar service lookup, then combines that with synchronous <code>IValidatableObject</code> rules.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="scenario4Form">
    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText class="form-control" @bind-Value="_event.Title" />
        <ValidationMessage For="@(() => _event.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <InputDate class="form-control" @bind-Value="_event.StartDate" />
        <ValidationMessage For="@(() => _event.StartDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <InputDate class="form-control" @bind-Value="_event.EndDate" />
        <ValidationMessage For="@(() => _event.EndDate)" />
    </div>

    <button type="submit" class="btn btn-primary">
        @(_isSubmitting ? "Validating asynchronously..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Event _event = new()
    {
        Title = "TBD Kickoff",
        StartDate = new DateTime(2026, 6, 1),
        EndDate = new DateTime(2026, 6, 2)
    };

    private EditContext _editContext = null!;
    private ValidationMessageStore _messageStore = null!;
    private CancellationTokenSource? _cts;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_event);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += OnFieldChanged;
    }

    private void OnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (_cts is not null && !_cts.IsCancellationRequested)
        {
            _cts.Cancel();
        }
    }

    private async Task HandleSubmit(EditContext _)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        _isSubmitting = true;
        _messageStore.Clear();
        _message = null;
        _editContext.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_event);

        try
        {
            bool isValid = await Validator.TryValidateObjectAsync(_event, context, results, true, _cts.Token);

            AddResultsToMessageStore(_editContext, _messageStore, _event, results);
            _message = isValid
                ? "✅ Event valid!"
                : "❌ Validation failed — see event errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStore.Clear();
            _editContext.NotifyValidationStateChanged();
            _message = "⚠️ Validation cancelled — a field value changed.";
            _alertClass = "alert-warning";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static void AddResultsToMessageStore(EditContext editContext, ValidationMessageStore messageStore, object model, IEnumerable<ValidationResult> results)
    {
        foreach (var result in results)
        {
            foreach (var member in result.MemberNames)
            {
                messageStore.Add(editContext.Field(member), result.ErrorMessage!);
            }

            if (!result.MemberNames.Any())
            {
                messageStore.Add(new FieldIdentifier(model, string.Empty), result.ErrorMessage!);
            }
        }

        editContext.NotifyValidationStateChanged();
    }

    public void Dispose()
    {
        _editContext.OnFieldChanged -= OnFieldChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
