@page "/scenario2"
@implements IDisposable

<h3>Scenario 2 — Order</h3>
<p>
    <code>Order</code> demonstrates the second API proposal scenario: a sync
    <code>IValidatableObject</code> model with async property validation on
    <code>ProductName</code>. Field changes run <code>[AsyncProductExists]</code>, while submit runs
    <code>ValidateAsync()</code> for the full model, including <code>[AsyncInventoryCheck]</code>
    and <code>Validate()</code>.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="scenario2Form">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Product Name</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_order.ProductName" />
            @if (_editContext.IsValidationPending(() => _order.ProductName))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _order.ProductName)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <InputNumber class="form-control" @bind-Value="_order.Quantity" />
        <ValidationMessage For="@(() => _order.Quantity)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Unit Price</label>
        <InputNumber class="form-control" @bind-Value="_order.UnitPrice" />
        <ValidationMessage For="@(() => _order.UnitPrice)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_order.Delay" />
        <ValidationMessage For="@(() => _order.Delay)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating...
        }
        else
        {
            @:Submit
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Order _order = new()
    {
        ProductName = "Widget",
        Quantity = 150,
        UnitPrice = 20m,
        Delay = 200
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_order);
        _editContext.OnValidationStateChanged += HandleValidationStateChanged;
    }

    private void HandleValidationStateChanged(object? sender, ValidationStateChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Scenario 2 passed — property, attribute, and IValidatableObject checks all succeeded."
                : "❌ Scenario 2 failed — see the validation messages above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    public void Dispose()
    {
        _editContext.OnValidationStateChanged -= HandleValidationStateChanged;
    }
}
