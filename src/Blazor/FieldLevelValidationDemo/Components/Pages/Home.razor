<h4 class="mt-4">New EditContext APIs</h4>
<table class="table table-bordered table-sm">
    <thead class="table-light">
        <tr>
            <th>API</th>
            <th>Purpose</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><code>ValidateAsync()</code></td>
            <td>Async submit validation for the whole model</td>
        </tr>
        <tr>
            <td><code>AddValidationTask(field, task, cts)</code></td>
            <td>Tracks async validation work and cancels superseded field checks</td>
        </tr>
        <tr>
            <td><code>IsValidationPending(field)</code></td>
            <td>Returns <code>true</code> while a field's async validation is in flight</td>
        </tr>
        <tr>
            <td><code>IsValidationFaulted(field)</code></td>
            <td>Returns <code>true</code> if a field's async validation threw an exception</td>
        </tr>
        <tr>
            <td><code>OnAsyncValidationRequested</code></td>
            <td>Async submit hook used by the validator pipeline</td>
        </tr>
    </tbody>
</table>
