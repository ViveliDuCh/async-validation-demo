@page "/comparison"
@using System.Diagnostics
@implements IDisposable

<h3>Side-by-Side: Manual Form-Level vs Built-In Field-Level</h3>
<p>
    Both panels validate the same <code>User</code> model. The left keeps the manual
    form-level pattern with <code>Validator.TryValidateObjectAsync</code>; the right uses
    <code>&lt;DataAnnotationsValidator /&gt;</code> plus <code>await _editContext.ValidateAsync()</code>.
</p>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <strong>Manual form-level validation</strong>
                <span class="badge bg-warning text-dark ms-2">More plumbing</span>
            </div>
            <div class="card-body">
                <EditForm EditContext="@_editContextLeft" OnSubmit="@HandleSubmitLeft" FormName="manualUserForm">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_userLeft.Name" />
                        <ValidationMessage For="@(() => _userLeft.Name)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText class="form-control" @bind-Value="_userLeft.Username" />
                        <ValidationMessage For="@(() => _userLeft.Username)" />
                    </div>
                    <button type="submit" class="btn btn-secondary" disabled="@_isSubmittingLeft">
                        @(_isSubmittingLeft ? "Validating asynchronously..." : "Submit")
                    </button>
                    <ValidationSummary class="mt-3" />
                </EditForm>

                @if (_messageLeft is not null)
                {
                    <div class="alert @_alertClassLeft mt-3">@_messageLeft</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <strong>DataAnnotationsValidator</strong>
                <span class="badge bg-success ms-2">Built-in pattern</span>
            </div>
            <div class="card-body">
                <EditForm EditContext="@_editContextRight" OnSubmit="@HandleSubmitRight" FormName="builtInUserForm">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_userRight.Name" />
                        <ValidationMessage For="@(() => _userRight.Name)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <div class="input-group">
                            <InputText class="form-control" @bind-Value="_userRight.Username" />
                            @if (_editContextRight.IsValidationPending(() => _userRight.Username))
                            {
                                <span class="input-group-text">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                </span>
                            }
                        </div>
                        <ValidationMessage For="@(() => _userRight.Username)" />
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@(_isSubmittingRight || _editContextRight.IsValidationPending())">
                        @if (_isSubmittingRight || _editContextRight.IsValidationPending())
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            @:Validating...
                        }
                        else
                        {
                            @:Submit
                        }
                    </button>

                    <ValidationSummary class="mt-3" />
                </EditForm>

                @if (_messageRight is not null)
                {
                    <div class="alert @_alertClassRight mt-3">@_messageRight</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly User _userLeft = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private readonly User _userRight = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private EditContext _editContextLeft = null!;
    private ValidationMessageStore _messageStoreLeft = null!;
    private CancellationTokenSource? _ctsLeft;
    private bool _isSubmittingLeft;
    private string? _messageLeft;
    private string _alertClassLeft = "alert-info";

    private EditContext _editContextRight = null!;
    private bool _isSubmittingRight;
    private string? _messageRight;
    private string _alertClassRight = "alert-info";

    protected override void OnInitialized()
    {
        _editContextLeft = new EditContext(_userLeft);
        _messageStoreLeft = new ValidationMessageStore(_editContextLeft);
        _editContextLeft.OnFieldChanged += OnFieldChangedLeft;

        _editContextRight = new EditContext(_userRight);
        _editContextRight.OnValidationStateChanged += HandleValidationStateChangedRight;
    }

    private void OnFieldChangedLeft(object? sender, FieldChangedEventArgs e)
    {
        if (_ctsLeft is not null && !_ctsLeft.IsCancellationRequested)
        {
            _ctsLeft.Cancel();
        }
    }

    private void HandleValidationStateChangedRight(object? sender, ValidationStateChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    private async Task HandleSubmitLeft(EditContext _)
    {
        _ctsLeft?.Cancel();
        _ctsLeft?.Dispose();
        _ctsLeft = new CancellationTokenSource();

        _isSubmittingLeft = true;
        _messageStoreLeft.Clear();
        _messageLeft = null;
        _editContextLeft.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);

        var results = new List<ValidationResult>();
        var context = new ValidationContext(_userLeft);

        try
        {
            var sw = Stopwatch.StartNew();
            bool isValid = await Validator.TryValidateObjectAsync(
                _userLeft, context, results, true, _ctsLeft.Token);
            sw.Stop();

            foreach (var result in results)
            {
                foreach (var member in result.MemberNames)
                {
                    _messageStoreLeft.Add(_editContextLeft.Field(member), result.ErrorMessage!);
                }

                if (!result.MemberNames.Any())
                {
                    _messageStoreLeft.Add(new FieldIdentifier(_userLeft, string.Empty), result.ErrorMessage!);
                }
            }

            _editContextLeft.NotifyValidationStateChanged();
            _messageLeft = isValid
                ? $"✅ Valid! ({sw.ElapsedMilliseconds}ms)"
                : $"❌ Failed ({sw.ElapsedMilliseconds}ms)";
            _alertClassLeft = isValid ? "alert-success" : "alert-danger";
        }
        catch (OperationCanceledException)
        {
            _messageStoreLeft.Clear();
            _editContextLeft.NotifyValidationStateChanged();
            _messageLeft = "⚠️ Cancelled";
            _alertClassLeft = "alert-warning";
        }
        finally
        {
            _isSubmittingLeft = false;
        }
    }

    private async Task HandleSubmitRight()
    {
        _isSubmittingRight = true;
        _messageRight = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContextRight.ValidateAsync();
            _messageRight = isValid
                ? "✅ Valid! (DataAnnotationsValidator + ValidateAsync())"
                : "❌ Failed (DataAnnotationsValidator + ValidateAsync())";
            _alertClassRight = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmittingRight = false;
        }
    }

    public void Dispose()
    {
        _editContextLeft.OnFieldChanged -= OnFieldChangedLeft;
        _editContextRight.OnValidationStateChanged -= HandleValidationStateChangedRight;
        _ctsLeft?.Cancel();
        _ctsLeft?.Dispose();
    }
}
