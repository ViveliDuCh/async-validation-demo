@page "/event"

<h3>Field-Level Event — IValidatableObject + DataAnnotationsValidator</h3>
<p>
    <strong>Event</strong> implements <code>IValidatableObject</code> for sync entity checks
    and uses <code>[ReservedTitleCheck]</code> as an async property attribute.
    Field-level: changing Title triggers <code>TryValidatePropertyAsync</code> which runs
    <code>[ReservedTitleCheck]</code> asynchronously. Form-level: <code>ValidateAsync()</code>
    runs the full object including <code>[DateRange]</code>, <code>[AsyncScheduleCheck]</code>,
    and inline <code>Validate()</code>.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="fieldEventForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Title</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_event.Title" />
            @if (_editContext.IsValidationPending(() => _event.Title))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _event.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <InputDate class="form-control" @bind-Value="_event.StartDate" />
        <ValidationMessage For="@(() => _event.StartDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <InputDate class="form-control" @bind-Value="_event.EndDate" />
        <ValidationMessage For="@(() => _event.EndDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Simulated I/O Delay (ms)</label>
        <InputNumber class="form-control" @bind-Value="_event.Delay" />
        <ValidationMessage For="@(() => _event.Delay)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating...
        }
        else
        {
            @:Submit
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly Event _event = new()
    {
        Title = "TBD Planning",
        StartDate = new DateTime(DateTime.Today.Year + 1, 1, 1),
        EndDate = new DateTime(DateTime.Today.Year + 1, 1, 2),
        Delay = 100
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_event);
        _editContext.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Event valid — field-level [ReservedTitleCheck] + entity-level IValidatableObject both passed!"
                : "❌ Validation failed — see event errors above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
