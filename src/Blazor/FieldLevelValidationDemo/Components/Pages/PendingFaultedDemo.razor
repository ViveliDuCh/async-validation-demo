@page "/pending-faulted"
@implements IDisposable

<h3>Pending &amp; Faulted State — Per-Field Async Tracking</h3>
<p>
    These <code>EditContext</code> APIs track async validation state. This page uses the new
    scenario models directly: <code>User</code> for pending state and <code>UserRegistration</code>
    for the simulated infrastructure-failure path.
</p>

<hr />

<h4>1. IsValidationPending — Scenario 1 User</h4>
<p>
    <code>User.Name</code> uses sync <code>[IsValidName]</code>, so it completes immediately.
    <code>User.Username</code> uses async <code>[UsernameAvailableAsync]</code>, so it shows a
    spinner while the availability check is running.
</p>

<EditForm EditContext="@_editContext1" OnSubmit="@HandleSubmit1" FormName="pendingForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="_user.Name" />
        <ValidationMessage For="@(() => _user.Name)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_user.Username" />
            @if (_editContext1.IsValidationPending(() => _user.Username))
            {
                <span class="input-group-text text-primary">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span class="ms-1">Checking...</span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _user.Username)" />
    </div>

    @if (_editContext1.IsValidationPending())
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            Async validation is in progress for one or more fields...
        </div>
    }

    <button type="submit" class="btn btn-primary" disabled="@_editContext1.IsValidationPending()">
        @(_editContext1.IsValidationPending() ? "Waiting for validation..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message1 is not null)
{
    <div class="alert @_alertClass1 mt-3">@_message1</div>
}

<hr class="my-4" />

<h4>2. IsValidationFaulted — Simulated Infrastructure Error</h4>
<p>
    <code>User</code> has no faulted path, so this section keeps <code>UserRegistration</code> with
    username <code>error-trigger</code>. That causes <code>UserService</code> to throw, which lets
    <code>DataAnnotationsValidator</code> mark the field as <strong>faulted</strong>.
</p>

<EditForm EditContext="@_editContext2" OnSubmit="@HandleSubmit2" FormName="faultedForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_registration.Username" />
            @if (_editContext2.IsValidationPending(() => _registration.Username))
            {
                <span class="input-group-text text-primary">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
            @if (_editContext2.IsValidationFaulted(() => _registration.Username))
            {
                <span class="input-group-text text-danger">⚠️ Faulted</span>
            }
        </div>
        <ValidationMessage For="@(() => _registration.Username)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" type="email" @bind-Value="_registration.Email" />
        <ValidationMessage For="@(() => _registration.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_registration.Password" />
        <ValidationMessage For="@(() => _registration.Password)" />
    </div>

    @if (_editContext2.IsValidationFaulted())
    {
        <div class="alert alert-danger">
            <strong>⚠️ Validation infrastructure error:</strong> one or more async validators threw
            instead of returning a validation message.
        </div>
    }

    <button type="submit" class="btn btn-danger">Submit (will trigger error)</button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message2 is not null)
{
    <div class="alert @_alertClass2 mt-3">@_message2</div>
}

@code {
    private readonly User _user = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private readonly UserRegistration _registration = new()
    {
        Username = "error-trigger",
        Email = "new@example.com",
        Password = "SecureP@ss123"
    };

    private EditContext _editContext1 = null!;
    private EditContext _editContext2 = null!;
    private string? _message1;
    private string _alertClass1 = "alert-info";
    private string? _message2;
    private string _alertClass2 = "alert-info";

    protected override void OnInitialized()
    {
        _editContext1 = new EditContext(_user);
        _editContext1.OnValidationStateChanged += HandleValidationStateChanged1;

        _editContext2 = new EditContext(_registration);
        _editContext2.OnValidationStateChanged += HandleValidationStateChanged2;
    }

    private void HandleValidationStateChanged1(object? sender, ValidationStateChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    private void HandleValidationStateChanged2(object? sender, ValidationStateChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    private async Task HandleSubmit1()
    {
        bool isValid = await _editContext1.ValidateAsync();
        _message1 = isValid
            ? "✅ Pending-state demo passed."
            : "❌ Pending-state demo failed — see the validation messages above.";
        _alertClass1 = isValid ? "alert-success" : "alert-danger";
    }

    private async Task HandleSubmit2()
    {
        bool isValid = await _editContext2.ValidateAsync();
        _message2 = isValid
            ? "✅ Validation passed (unexpected if error-trigger was used)."
            : "❌ Validation failed — see the validation messages above.";
        _alertClass2 = isValid ? "alert-success" : "alert-danger";
    }

    public void Dispose()
    {
        _editContext1.OnValidationStateChanged -= HandleValidationStateChanged1;
        _editContext2.OnValidationStateChanged -= HandleValidationStateChanged2;
    }
}
