@page "/pending-faulted"
@inject IServiceProvider ServiceProvider

<h3>Pending &amp; Faulted State — Per-Field Async Tracking</h3>
<p>
    These new <code>EditContext</code> APIs track per-field async validation state:
    <code>IsValidationPending()</code> indicates a field's async check is in flight,
    <code>IsValidationFaulted()</code> indicates a field's async check threw an exception.
</p>

<hr />

<h4>1. IsValidationPending — Loading Indicators</h4>
<p>
    Type in the Username or Email field, then tab out. The <code>[UniqueUsername]</code>
    and <code>[UniqueEmail]</code> async attributes will run, showing a spinner while pending.
</p>

<EditForm EditContext="@_editContext1" OnSubmit="@HandleSubmit1" FormName="pendingForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_registration1.Username" />
            @if (_editContext1.IsValidationPending(() => _registration1.Username))
            {
                <span class="input-group-text text-primary">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span class="ms-1">Checking...</span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _registration1.Username)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <div class="input-group">
            <InputText class="form-control" type="email" @bind-Value="_registration1.Email" />
            @if (_editContext1.IsValidationPending(() => _registration1.Email))
            {
                <span class="input-group-text text-primary">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span class="ms-1">Checking...</span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _registration1.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_registration1.Password" />
        <ValidationMessage For="@(() => _registration1.Password)" />
    </div>

    @if (_editContext1.IsValidationPending())
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            Async validation in progress for one or more fields...
        </div>
    }

    <button type="submit" class="btn btn-primary" disabled="@_editContext1.IsValidationPending()">
        @(_editContext1.IsValidationPending() ? "Waiting for validation..." : "Submit")
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message1 is not null)
{
    <div class="alert @_alertClass1 mt-3">@_message1</div>
}

<hr class="my-4" />

<h4>2. IsValidationFaulted — Infrastructure Error Detection</h4>
<p>
    The username <code>error-trigger</code> causes <code>UserService</code> to throw an
    <code>InvalidOperationException</code>. The <code>DataAnnotationsValidator</code> catches
    this via <code>ObserveValidationTaskAsync</code> and marks the field as <strong>faulted</strong>.
</p>

<EditForm EditContext="@_editContext2" OnSubmit="@HandleSubmit2" FormName="faultedForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_registration2.Username" />
            @if (_editContext2.IsValidationPending(() => _registration2.Username))
            {
                <span class="input-group-text text-primary">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
            @if (_editContext2.IsValidationFaulted(() => _registration2.Username))
            {
                <span class="input-group-text text-danger">
                    ⚠️ Faulted
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _registration2.Username)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" type="email" @bind-Value="_registration2.Email" />
        <ValidationMessage For="@(() => _registration2.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText class="form-control" type="password" @bind-Value="_registration2.Password" />
        <ValidationMessage For="@(() => _registration2.Password)" />
    </div>

    @if (_editContext2.IsValidationFaulted())
    {
        <div class="alert alert-danger">
            <strong>⚠️ Validation infrastructure error:</strong> One or more fields had their async
            validation fail due to an infrastructure exception (e.g., database unreachable).
        </div>
    }

    <button type="submit" class="btn btn-danger">
        Submit (will trigger error)
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message2 is not null)
{
    <div class="alert @_alertClass2 mt-3">@_message2</div>
}

@code {
    private readonly UserRegistration _registration1 = new()
    {
        Username = "admin",
        Email = "admin@example.com",
        Password = "SecureP@ss123"
    };

    private readonly UserRegistration _registration2 = new()
    {
        Username = "error-trigger",
        Email = "new@example.com",
        Password = "SecureP@ss123"
    };

    private EditContext _editContext1 = null!;
    private EditContext _editContext2 = null!;
    private string? _message1;
    private string _alertClass1 = "alert-info";
    private string? _message2;
    private string _alertClass2 = "alert-info";

    protected override void OnInitialized()
    {
        _editContext1 = new EditContext(_registration1);
        _editContext1.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);

        _editContext2 = new EditContext(_registration2);
        _editContext2.OnValidationStateChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit1()
    {
        bool isValid = await _editContext1.ValidateAsync();
        _message1 = isValid
            ? "✅ All validation passed!"
            : "❌ Validation failed — see errors above.";
        _alertClass1 = isValid ? "alert-success" : "alert-danger";
    }

    private async Task HandleSubmit2()
    {
        bool isValid = await _editContext2.ValidateAsync();
        _message2 = isValid
            ? "✅ Validation passed (unexpected if error-trigger was used)."
            : "❌ Validation failed — see errors above.";
        _alertClass2 = isValid ? "alert-success" : "alert-danger";
    }
}
