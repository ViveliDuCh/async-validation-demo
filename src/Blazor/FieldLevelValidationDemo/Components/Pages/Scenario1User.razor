@page "/scenario1"
@implements IDisposable

<h3>Scenario 1 — User</h3>
<p>
    <code>User</code> matches the first API proposal scenario: no validation interface, one sync
    property attribute (<code>[IsValidName]</code>) and one async property attribute
    (<code>[UsernameAvailableAsync]</code>). Name validation completes immediately; Username shows
    <code>IsValidationPending()</code> while the async availability check runs.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="scenario1Form">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="_user.Name" />
        <ValidationMessage For="@(() => _user.Name)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
            <InputText class="form-control" @bind-Value="_user.Username" />
            @if (_editContext.IsValidationPending(() => _user.Username))
            {
                <span class="input-group-text">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                </span>
            }
        </div>
        <ValidationMessage For="@(() => _user.Username)" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating...
        }
        else
        {
            @:Submit
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly User _user = new()
    {
        Name = "Alice",
        Username = "admin"
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_user);
        _editContext.OnValidationStateChanged += HandleValidationStateChanged;
    }

    private void HandleValidationStateChanged(object? sender, ValidationStateChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Scenario 1 passed — sync name + async username checks are both valid."
                : "❌ Scenario 1 failed — see the validation messages above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    public void Dispose()
    {
        _editContext.OnValidationStateChanged -= HandleValidationStateChanged;
    }
}
