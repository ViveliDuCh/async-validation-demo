@page "/scenario3"
@implements IDisposable

<h3>Scenario 3 — MoneyTransfer</h3>
<p>
    <code>MoneyTransfer</code> demonstrates the third API proposal scenario:
    <code>IAsyncValidatableObject</code>. The property attributes are sync-only, so field-level
    validation completes immediately. The async work happens during submit when
    <code>await _editContext.ValidateAsync()</code> calls <code>ValidateAsync()</code>.
</p>

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit" FormName="scenario3Form">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">From Account</label>
        <InputText class="form-control" @bind-Value="_transfer.FromAccount" />
        <ValidationMessage For="@(() => _transfer.FromAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">To Account</label>
        <InputText class="form-control" @bind-Value="_transfer.ToAccount" />
        <ValidationMessage For="@(() => _transfer.ToAccount)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <InputNumber class="form-control" @bind-Value="_transfer.Amount" />
        <ValidationMessage For="@(() => _transfer.Amount)" />
    </div>

    @if (_editContext.IsValidationPending())
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            Async submit validation is running...
        </div>
    }

    <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _editContext.IsValidationPending())">
        @if (_isSubmitting || _editContext.IsValidationPending())
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            @:Validating...
        }
        else
        {
            @:Submit
        }
    </button>

    <ValidationSummary class="mt-3" />
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3">@_message</div>
}

@code {
    private readonly MoneyTransfer _transfer = new()
    {
        FromAccount = "CHK-001",
        ToAccount = "CHK-001",
        Amount = 750m
    };

    private EditContext _editContext = null!;
    private bool _isSubmitting;
    private string? _message;
    private string _alertClass = "alert-info";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_transfer);
        _editContext.OnValidationStateChanged += HandleValidationStateChanged;
    }

    private void HandleValidationStateChanged(object? sender, ValidationStateChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            bool isValid = await _editContext.ValidateAsync();
            _message = isValid
                ? "✅ Scenario 3 passed — async transfer validation succeeded on submit."
                : "❌ Scenario 3 failed — see the validation messages above.";
            _alertClass = isValid ? "alert-success" : "alert-danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    public void Dispose()
    {
        _editContext.OnValidationStateChanged -= HandleValidationStateChanged;
    }
}
