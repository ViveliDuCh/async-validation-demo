<Window x:Class="AsyncManualSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF AsyncManualSample — 4 API Proposal Scenarios" Height="560" Width="760">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self},
                                   Path=(Validation.Errors)[0].ErrorContent}"/>
                    <Setter Property="BorderBrush" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <TabControl Margin="10">
        <TabItem Header="Scenario 1 (User)">
            <StackPanel Margin="10" DataContext="{Binding UserVM}">
                <TextBlock Text="Scenario 1: User" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="No interface — sync [IsValidName] + async [UsernameAvailableAsync]." Margin="0,0,0,10"/>

                <Label Content="Name"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Username"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateUser_Click"/>
                <TextBlock x:Name="UserResult" Margin="0,5,0,0" Foreground="DarkRed" TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Scenario 2 (Order)">
            <StackPanel Margin="10" DataContext="{Binding OrderVM}">
                <TextBlock Text="Scenario 2: Order" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="IValidatableObject — async attributes + sync Validate() business rule." Margin="0,0,0,10"/>

                <Label Content="Product Name"/>
                <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Quantity"/>
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Unit Price"/>
                <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Delay (ms)"/>
                <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateOrder_Click"/>
                <TextBlock x:Name="OrderResult" Margin="0,5,0,0" Foreground="DarkRed" TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Scenario 3 (MoneyTransfer)">
            <StackPanel Margin="10" DataContext="{Binding MoneyTransferVM}">
                <TextBlock Text="Scenario 3: MoneyTransfer" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="IAsyncValidatableObject — async cross-property validation via ValidateAsync()." Margin="0,0,0,10"/>

                <Label Content="From Account"/>
                <TextBox Text="{Binding FromAccount, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="To Account"/>
                <TextBox Text="{Binding ToAccount, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Amount"/>
                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateMoneyTransfer_Click"/>
                <TextBlock x:Name="MoneyTransferResult" Margin="0,5,0,0" Foreground="DarkRed" TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Scenario 4 (Event)">
            <StackPanel Margin="10" DataContext="{Binding EventVM}">
                <TextBlock Text="Scenario 4: Event" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Async [AsyncDateRangeValid] + sync IValidatableObject validation." Margin="0,0,0,10"/>

                <Label Content="Title"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Start Date"/>
                <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="End Date"/>
                <DatePicker SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateEvent_Click"/>
                <TextBlock x:Name="EventResult" Margin="0,5,0,0" Foreground="DarkRed" TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
