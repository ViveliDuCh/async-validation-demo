<Window x:Class="AsyncToolkitSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF AsyncToolkitSample — CommunityToolkit.Mvvm + Async Validation" Height="500" Width="700">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self},
                                   Path=(Validation.Errors)[0].ErrorContent}"/>
                    <Setter Property="BorderBrush" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <TabControl Margin="10">
        <TabItem Header="User Registration">
            <StackPanel Margin="10" DataContext="{Binding UserRegistrationVM}">
                <TextBlock Text="Scenario 1: DI-backed registration validation (ObservableValidator)" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="UserRegistration uses ObservableValidator for sync property errors and async entity validation with UserService DI." Margin="0,0,0,10"/>

                <Label Content="Username"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Email"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Password"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateUserRegistration_Click"/>
                <TextBlock x:Name="UserRegistrationResult" Margin="0,5,0,0" Foreground="DarkRed"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Event">
            <StackPanel Margin="10" DataContext="{Binding EventVM}">
                <TextBlock Text="Scenario 3: Async Entity-Level Attribute (ObservableValidator)" FontWeight="Bold" Margin="0,0,0,10"/>

                <Label Content="Title"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Start Date"/>
                <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="End Date"/>
                <DatePicker SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Delay (ms)"/>
                <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateEvent_Click"/>
                <TextBlock x:Name="EventResult" Margin="0,5,0,0" Foreground="DarkRed"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="Order">
            <StackPanel Margin="10" DataContext="{Binding OrderVM}">
                <TextBlock Text="Scenario 4: IAsyncValidatableObject (ObservableValidator)" FontWeight="Bold" Margin="0,0,0,10"/>

                <Label Content="Product Name"/>
                <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                <Label Content="Quantity"/>
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Unit Price"/>
                <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Delay (ms)"/>
                <TextBox Text="{Binding Delay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Validate All (Async)" Margin="0,10,0,0" Click="ValidateOrder_Click"/>
                <TextBlock x:Name="OrderResult" Margin="0,5,0,0" Foreground="DarkRed"/>
            </StackPanel>
        </TabItem>

    </TabControl>
</Window>
